APP_NAME=Panvel AI Assistant API
APP_VERSION=0.1.0
APP_ENV=local
APP_DEBUG=false
LOG_LEVEL=INFO

# LLM Configuration
# Providers: gemini | openai | mock
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# Embedding Configuration
EMBEDDING_PROVIDER=gemini

# Vector Store path (use /app/.vector_store for Docker, or local path for local dev)
VECTOR_STORE_PATH=/app/.vector_store
